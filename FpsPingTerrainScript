-- config
local cfgFile="BlockVNHub.json"
local cfg={low=false,bright=false}

if isfile and isfile(cfgFile) then
	pcall(function()
		cfg=HttpService:JSONDecode(readfile(cfgFile))
	end)
end

local function saveCfg()
	if writefile then
		writefile(cfgFile,HttpService:JSONEncode(cfg))
	end
end

