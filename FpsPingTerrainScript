			if v~=note then
				v.Visible=uiVisible
			end
		end
	end
end)

local saved={}
local brightConn=nil

local function applyLow(state)
	cfg.low=state
	saveCfg()

	b1.Text=state and "Lag: ON" or "Lag: OFF"

	for _,v in ipairs(workspace:GetDescendants()) do
		if v:IsA("BasePart") and not v:IsDescendantOf(plr.Character) then
			if state then
				saved[v]=v.LocalTransparencyModifier
				v.LocalTransparencyModifier=1
			else
				v.LocalTransparencyModifier=saved[v] or 0
			end

		elseif v:IsA("Decal") or v:IsA("Texture") then
			if state then
				saved[v]=v.Transparency
				v.Transparency=1
			else
				v.Transparency=saved[v] or 0
			end

		elseif v:IsA("ParticleEmitter") or v:IsA("Trail") then
			if state then
				saved[v]=v.Enabled
				v.Enabled=false
			else
				v.Enabled=saved[v]~=false
			end
		end
	end
end

local function applyBright(state)
	cfg.bright=state
	saveCfg()

	b2.Text=state and "Bright: ON" or "Bright: OFF"

	if state then
		if not brightConn then
			brightConn=RS.RenderStepped:Connect(function()
				Lighting.Brightness=5
				Lighting.ClockTime=14
				Lighting.FogEnd=100000
				Lighting.GlobalShadows=false
				Lighting.Ambient=Color3.new(1,1,1)
				Lighting.OutdoorAmbient=Color3.new(1,1,1)
			end)
		end
	else
		if brightConn then
			brightConn:Disconnect()
			brightConn=nil
		end
	end
end

b1.MouseButton1Click:Connect(function()
	applyLow(not cfg.low)
end)

b2.MouseButton1Click:Connect(function()
	applyBright(not cfg.bright)
end)

-- restore config
task.wait(0.5)

applyLow(cfg.low)
applyBright(cfg.bright)

-- fps/ping update
local fps,last,frames=0,tick(),0

RS.RenderStepped:Connect(function()
	frames+=1

	local now=tick()

	if now-last>=0.25 then
		fps=math.floor(frames/(now-last))

		frames=0
		last=now

		local pingStr=Stats.Network.ServerStatsItem["Data Ping"]:GetValueString()
		local ping=tonumber(pingStr:match("%d+")) or 0

		l.Text=("FPS: %d | Ping: %d ms"):format(fps,ping)
	end

	-- rainbow text
	local rainbow=Color3.fromHSV((tick()%5)/5,1,1)

	l.TextColor3=rainbow

	-- rainbow outlines
	for _,stroke in ipairs(rainbowObjects) do
		stroke.Color=rainbow
	end
end)
