-- nút lag
local b1=Instance.new("TextButton",gui)
b1.Size=UDim2.new(0,100,0,35)
b1.Position=UDim2.new(0.5,-100,0,35)
b1.BackgroundColor3=Color3.fromRGB(40,40,40)
b1.TextColor3=Color3.new(1,1,1)
