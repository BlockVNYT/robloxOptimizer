-- ─── FIX TRIỆT ĐỂ LỖI KHÔNG HIỆN LẠI PLAYER KHI TẮT ─────────────────────────
local hideConn = nil
local savedPlayersTransparency = {} 

local function applyHideToCharacter(character)
	if not character or not character:IsDescendantOf(workspace) then return end

	for _, part in ipairs(character:GetDescendants()) do
		if part:IsA("BasePart") or part:IsA("Decal") then
			-- Loại trừ các thành phần hệ thống ẩn sẵn của Roblox (ví dụ: khối va chạm Root)
			if part.Name == "HumanoidRootPart" or part.Name == "CollisionPart" then
				if cfg.hidePlayersEnabled then
					part.Transparency = 1
				end
			else
				if cfg.hidePlayersEnabled then
					-- Lưu thuộc tính trong suốt gốc trước khi ẩn ẩn hoàn toàn (1)
					if savedPlayersTransparency[part] == nil then
						savedPlayersTransparency[part] = part.Transparency
					end
					part.Transparency = 1
				else
					-- Khi TẮT: Trả về độ trong suốt gốc. Nếu mất dữ liệu tạm, ép về 0 (Hiển thị hoàn toàn)
					if savedPlayersTransparency[part] ~= nil then
						part.Transparency = savedPlayersTransparency[part]
					else
						part.Transparency = 0
					end
				end
			end
		elseif part:IsA("BillboardGui") or part:IsA("SurfaceGui") then
			part.Enabled = not cfg.hidePlayersEnabled
		end
	end
end

local function applyHidePlayers(state)
	cfg.hidePlayersEnabled = state
	saveCfg()
	hidePlayersBtn.Text = state and "Hide All Players: ON" or "Hide All Players: OFF"
	hidePlayersBtn.BackgroundColor3 = state and Color3.fromRGB(20, 80, 20) or Color3.fromRGB(30, 30, 30)

	-- Thực thi quét toàn server ngay lập tức
	for _, p in ipairs(Players:GetPlayers()) do
		if p.Character then
			applyHideToCharacter(p.Character)
		end
	end

	if state then
		if not hideConn then
			hideConn = workspace.DescendantAdded:Connect(function(v)
				for _, p in ipairs(Players:GetPlayers()) do
					if p.Character and v:IsDescendantOf(p.Character) then
						task.defer(function()
							if v:IsA("BasePart") or v:IsA("Decal") then
								if v.Name ~= "HumanoidRootPart" then
									if savedPlayersTransparency[v] == nil then
										savedPlayersTransparency[v] = v.Transparency
									end
								end
								v.Transparency = 1
							end
						end)
						break
					end
				end
			end)
		end
	else
		if hideConn then hideConn:Disconnect() hideConn = nil end
		-- Dọn dẹp bảng nhớ tạm sau khi đã khôi phục thành công các nhân vật
		task.delay(0.2, function()
			savedPlayersTransparency = {}
		end)
	end
end

