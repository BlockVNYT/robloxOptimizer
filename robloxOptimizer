-- FPS/Ping loop
local fps, last, frames = 0, tick(), 0
RS.RenderStepped:Connect(function()
	frames += 1
	local now = tick()
	if now - last >= 0.25 then
		fps = math.floor(frames / (now - last))
		frames = 0
		last = now
		local ping = 0
		pcall(function()
			local pingStr = Stats.Network.ServerStatsItem["Data Ping"]:GetValueString()
			local num = pingStr:match("(%d+%.?%d*)")
			ping = num and math.floor(tonumber(num)) or 0
		end)
		l.Text = ("FPS: %d | Ping: %d ms"):format(fps, ping)
	end
	l.TextColor3 = Color3.fromHSV((tick() % 5) / 5, 1, 1)
end)

