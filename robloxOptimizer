local function updateDrag(input)
	local delta = input.Position - dragStart
	for _, obj in ipairs(draggableObjects) do
		if obj and obj.Parent then
			obj.Position = UDim2.new(
				startPos[obj].X.Scale,
				startPos[obj].X.Offset + delta.X,
				startPos[obj].Y.Scale,
				startPos[obj].Y.Offset + delta.Y
			)
		end
	end
end

l.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		drag = true
		dragStart = input.Position
		startPos = {}
		for _, obj in ipairs(draggableObjects) do 
			if obj and obj.Parent then startPos[obj] = obj.Position end 
		end
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then drag = false end
		end)
	end
end)

l.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
end)

UIS.InputChanged:Connect(function(input)
	if drag and input == dragInput then updateDrag(input) end
end)

