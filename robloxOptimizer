-- Đọc cấu hình cũ nếu có dữ liệu đã lưu
if isfile and isfile(cfgFile) then
	pcall(function() 
		local decoded = HttpService:JSONDecode(readfile(cfgFile)) 
		if decoded and type(decoded) == "table" then
			for k, v in pairs(decoded) do
				cfg[k] = v
			end
		end
	end)
end

-- Hàm lưu cấu hình vào file
local function saveCfg()
	if writefile then 
		pcall(function()
			writefile(cfgFile, HttpService:JSONEncode(cfg)) 
		end)
	end
end
