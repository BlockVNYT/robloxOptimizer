-- ─── Less VFX ────────────────────────────────────────────────────────────────
local vfxSaved = {}
local vfxConn = nil

local function isOtherCharacter(v)
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= plr and p.Character and v:IsDescendantOf(p.Character) then
			return true
		end
	end
	return false
end

local function isVFXType(v)
	return v:IsA("ParticleEmitter")
		or v:IsA("Trail")
		or v:IsA("Smoke")
		or v:IsA("Fire")
		or v:IsA("Sparkles")
		or v:IsA("Beam")
		or v:IsA("SelectionBox")
end

local function isShadowCaster(v)
	return v:IsA("BasePart") or v:IsA("UnionOperation") or v:IsA("MeshPart")
end

local function applyVfxToObject(v)
	if not cfg.lessVfxEnabled then return end

	local char = plr.Character
	if isVFXType(v) and (not char or not v:IsDescendantOf(char)) then
		if vfxSaved[v] == nil then vfxSaved[v] = v.Enabled end
		v.Enabled = false
	elseif isShadowCaster(v) and (not char or not v:IsDescendantOf(char)) then
		if vfxSaved[v] == nil then vfxSaved[v] = v.CastShadow end
		v.CastShadow = false
	elseif (v:IsA("Decal") or v:IsA("Texture")) and isOtherCharacter(v) then
		if vfxSaved[v] == nil then vfxSaved[v] = v.Transparency end
		v.Transparency = 1
	elseif v:IsA("BasePart") and v.Name == "Handle" and isOtherCharacter(v) then
		if vfxSaved[v] == nil then vfxSaved[v] = v.LocalTransparencyModifier end
		v.LocalTransparencyModifier = 1
	end
end

local function applyLessVFX(state)
	cfg.lessVfxEnabled = state
	saveCfg()
	lessVfxBtn.Text = state and "Less VFX: ON" or "Less VFX: OFF"
	lessVfxBtn.BackgroundColor3 = state and Color3.fromRGB(80, 20, 20) or Color3.fromRGB(30, 30, 30)

	if state then
		Lighting.GlobalShadows = false
		for _, v in ipairs(workspace:GetDescendants()) do
			applyVfxToObject(v)
		end
		if not vfxConn then
			vfxConn = workspace.DescendantAdded:Connect(function(v)
				task.defer(applyVfxToObject, v)
			end)
		end
	else
		if vfxConn then vfxConn:Disconnect() vfxConn = nil end
		for v, original in pairs(vfxSaved) do
			pcall(function()
				if isVFXType(v) then v.Enabled = original
				elseif isShadowCaster(v) then v.CastShadow = original
				elseif v:IsA("Decal") or v:IsA("Texture") then v.Transparency = original
				elseif v:IsA("BasePart") then v.LocalTransparencyModifier = original end
			end)
		end
		vfxSaved = {}
		Lighting.GlobalShadows = getgenv().BlockVNOriginalLighting.GlobalShadows
	end
end

-- ─── Boost FPS & Remove Terrain Fix Realtime Spawning ─────────────────────────
local boostConn = nil
local terrainConn = nil

local function checkAndApplyBoostToObject(v)
	if not cfg.boostEnabled then return end
	if v:IsA("BasePart") and not v:IsDescendantOf(plr.Character) then
		if not savedBoost[v] then savedBoost[v] = v.Material end
		v.Material = Enum.Material.SmoothPlastic
		v.Reflectance = 0
	elseif v:IsA("Decal") or v:IsA("Texture") then
		if not savedBoost[v] then savedBoost[v] = v.Transparency end
		v.Transparency = 1
	elseif isVFXType(v) then
		if not savedBoost[v] then savedBoost[v] = v.Enabled end
		v.Enabled = false
	end
end

local function checkAndApplyTerrainToObject(v)
	if not cfg.terrainEnabled then return end
	if v:IsA("BasePart") and not v:IsDescendantOf(plr.Character) then
		if not savedTerrain[v] then savedTerrain[v] = v.LocalTransparencyModifier end
		v.LocalTransparencyModifier = 1
	elseif v:IsA("Decal") or v:IsA("Texture") then
		if not savedTerrain[v] then savedTerrain[v] = v.Transparency end
		v.Transparency = 1
	end
end

local function applyBoostFPS(state)
	cfg.boostEnabled = state
	saveCfg()
	boostBtn.Text = state and "Boost FPS: ON" or "Boost FPS: OFF"
	boostBtn.BackgroundColor3 = state and Color3.fromRGB(20, 80, 20) or Color3.fromRGB(30, 30, 30)

	local terrain = workspace:FindFirstChildOfClass("Terrain")
	if terrain then
		for _, mat in ipairs(Enum.Material:GetEnumItems()) do
			pcall(function()
				if state then terrain:SetMaterialColor(mat, Color3.fromRGB(50, 50, 50))
				else terrain:ResetMaterialColor(mat) end
			end)
		end
	end

	if state then
		for _, v in ipairs(workspace:GetDescendants()) do
			checkAndApplyBoostToObject(v)
		end
		if not boostConn then
			boostConn = workspace.DescendantAdded:Connect(function(v)
				task.defer(checkAndApplyBoostToObject, v)
			end)
		end
	else
		if boostConn then boostConn:Disconnect() boostConn = nil end
		for v, original in pairs(savedBoost) do
			pcall(function()
				if v:IsA("BasePart") then v.Material = original
				elseif v:IsA("Decal") or v:IsA("Texture") then v.Transparency = original
				elseif isVFXType(v) then v.Enabled = original end
			end)
		end
		savedBoost = {}
	end
end

local function applyRemoveTerrain(state)
	cfg.terrainEnabled = state
	saveCfg()
	terrainBtn.Text = state and "Remove Terrain: ON" or "Remove Terrain: OFF"
	terrainBtn.BackgroundColor3 = state and Color3.fromRGB(20, 80, 20) or Color3.fromRGB(30, 30, 30)

	if state then
		for _, v in ipairs(workspace:GetDescendants()) do
			checkAndApplyTerrainToObject(v)
		end
		if not terrainConn then
			terrainConn = workspace.DescendantAdded:Connect(function(v)
				task.defer(checkAndApplyTerrainToObject, v)
			end)
		end
	else
		if terrainConn then terrainConn:Disconnect() terrainConn = nil end
		for v, original in pairs(savedTerrain) do
			pcall(function()
				if v:IsA("BasePart") then v.LocalTransparencyModifier = original
				elseif v:IsA("Decal") or v:IsA("Texture") then v.Transparency = original end
			end)
		end
		savedTerrain = {}
	end
end

local function applyBright(mode)
	if brightConn then brightConn:Disconnect() brightConn = nil end
	cfg.modeIndex = mode
	saveCfg()
	updateEffectText()
	updateModeHighlight()
	if mode == 1 then
		b2.Text = "Mode: BRIGHT"
		brightConn = RS.RenderStepped:Connect(function()
			local intensity = math.clamp(cfg.effectLevel, 1, 10)
			Lighting.ClockTime = 14
			Lighting.FogEnd = 100000
			Lighting.GlobalShadows = false
			Lighting.Brightness = 1 + (intensity * 0.45)
			local ambient = 0.2 + (intensity * 0.075)
			Lighting.Ambient = Color3.new(ambient, ambient, ambient)
			Lighting.OutdoorAmbient = Color3.new(ambient, ambient, ambient)
			Lighting.ExposureCompensation = intensity * 0.22
		end)
	elseif mode == 2 then
		b2.Text = "Mode: OFF"
		local old = getgenv().BlockVNOriginalLighting
		Lighting.Brightness = old.Brightness
		Lighting.ClockTime = old.ClockTime
		Lighting.FogEnd = old.FogEnd
		Lighting.GlobalShadows = cfg.lessVfxEnabled and false or old.GlobalShadows
		Lighting.Ambient = old.Ambient
		Lighting.OutdoorAmbient = old.OutdoorAmbient
		Lighting.ExposureCompensation = old.ExposureCompensation
	elseif mode == 3 then
		b2.Text = "Mode: DARK"
		brightConn = RS.RenderStepped:Connect(function()
			local darkness = math.clamp(cfg.effectLevel, 1, 10)
			Lighting.ClockTime = 0
			Lighting.GlobalShadows = not cfg.lessVfxEnabled
			Lighting.FogEnd = 3000 - (darkness * 260)
			Lighting.Brightness = 1.5 - (darkness * 0.13)
			local ambient = math.clamp(0.6 - (darkness * 0.055), 0, 1)
			Lighting.Ambient = Color3.new(ambient, ambient, ambient)
			Lighting.OutdoorAmbient = Color3.new(ambient, ambient, ambient)
			Lighting.ExposureCompensation = -(darkness * 0.28)
		end)
	end
end

