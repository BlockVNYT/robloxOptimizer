-- ─── Less VFX (Cũ là Ultra FPS) ──────────────────────────────────────────────
local vfxSaved={}
local vfxConn=nil

local function isOtherCharacter(v)
	for _,p in ipairs(Players:GetPlayers()) do
		if p~=plr and p.Character and v:IsDescendantOf(p.Character) then
			return true
		end
	end
	return false
end

local function isVFXType(v)
	return v:IsA("ParticleEmitter")
		or v:IsA("Trail")
		or v:IsA("Smoke")
		or v:IsA("Fire")
		or v:IsA("Sparkles")
		or v:IsA("Beam")
		or v:IsA("SelectionBox")
end

local function isShadowCaster(v)
	return v:IsA("BasePart") or v:IsA("UnionOperation") or v:IsA("MeshPart") or v:IsA("SpecialMesh")
end

local function applyVfxToObject(v)
	if not lessVfxEnabled then return end

	if isVFXType(v) and not v:IsDescendantOf(plr.Character or game) then
		if vfxSaved[v]==nil then
			vfxSaved[v]=v.Enabled
		end
		v.Enabled=false

	elseif isShadowCaster(v)
		and not v:IsDescendantOf(plr.Character or game) then
		if vfxSaved[v]==nil then
			vfxSaved[v]=v.CastShadow
		end
		v.CastShadow=false

	elseif (v:IsA("Decal") or v:IsA("Texture")) and isOtherCharacter(v) then
		if vfxSaved[v]==nil then
			vfxSaved[v]=v.Transparency
		end
		v.Transparency=1

	elseif v:IsA("BasePart") and v.Name=="Handle" and isOtherCharacter(v) then
		if vfxSaved[v]==nil then
			vfxSaved[v]=v.LocalTransparencyModifier
		end
		v.LocalTransparencyModifier=1
	end
end

local function applyLessVFX(state)
	lessVfxEnabled=state
	lessVfxBtn.Text=state and "Less VFX: ON" or "Less VFX: OFF"
	lessVfxBtn.BackgroundColor3=state
		and Color3.fromRGB(80,20,20) or Color3.fromRGB(30,30,30)

	if state then
		Lighting.GlobalShadows=false

		for _,v in ipairs(workspace:GetDescendants()) do
			applyVfxToObject(v)
		end

		vfxConn=workspace.DescendantAdded:Connect(function(v)
			task.defer(applyVfxToObject,v)
		end)
	else
		if vfxConn then
			vfxConn:Disconnect()
			vfxConn=nil
		end

		for v,original in pairs(vfxSaved) do
			pcall(function()
				if isVFXType(v) then
					v.Enabled=original
				elseif isShadowCaster(v) then
					v.CastShadow=original
				elseif v:IsA("Decal") or v:IsA("Texture") then
					v.Transparency=original
				elseif v:IsA("BasePart") then
					v.LocalTransparencyModifier=original
				end
			end)
		end

		vfxSaved={}
		Lighting.GlobalShadows=getgenv().BlockVNOriginalLighting.GlobalShadows
	end
end
-- ─────────────────────────────────────────────────────────────────────────────

local function applyBoostFPS(state)
	boostEnabled=state
	boostBtn.Text=state and "Boost FPS: ON" or "Boost FPS: OFF"
	boostBtn.BackgroundColor3=state and Color3.fromRGB(20,80,20) or Color3.fromRGB(30,30,30)
	
	-- Phần xử lý khử màu sắc của Terrain (Xám hóa toàn bộ vật liệu terrain)
	local terrain = workspace:FindFirstChildOfClass("Terrain")
	if terrain then
		for _, mat in ipairs(Enum.Material:GetEnumItems()) do
			pcall(function()
				if state then
					terrain:SetMaterialColor(mat, Color3.fromRGB(50, 50, 50)) -- Biến thành màu xám đồng nhất
				else
					terrain:ResetMaterialColor(mat) -- Trả lại màu gốc khi Tắt Boost
				end
			end)
		end
	end

	for _,v in ipairs(workspace:GetDescendants()) do
		if v:IsA("Terrain") then
			if state then
				v.WaterWaveSize=0
				v.WaterWaveSpeed=0
				v.WaterReflectance=0
				v.WaterTransparency=1
			end
		elseif v:IsA("BasePart") and not v:IsDescendantOf(plr.Character) then
			if state then
				if not saved[v] then saved[v]=v.Material end
				v.Material=Enum.Material.SmoothPlastic
				v.Reflectance=0
			else
				if saved[v] then v.Material=saved[v] end
			end
		elseif v:IsA("Decal") or v:IsA("Texture") then
			if state then
				if not saved[v] then saved[v]=v.Transparency end
				v.Transparency=1
			else
				if saved[v] then v.Transparency=saved[v] end
			end
		elseif v:IsA("ParticleEmitter") or v:IsA("Trail")
			or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
			if state then
				if not saved[v] then saved[v]=v.Enabled end
				v.Enabled=false
			else
				if saved[v]~=nil then v.Enabled=saved[v] end
			end
		end
	end
	if not state then saved = {} end
end

local function applyRemoveTerrain(state)
	terrainEnabled=state
	terrainBtn.Text=state and "Remove Terrain: ON" or "Remove Terrain: OFF"
	terrainBtn.BackgroundColor3=state and Color3.fromRGB(20,80,20) or Color3.fromRGB(30,30,30)
	for _,v in ipairs(workspace:GetDescendants()) do
		if v:IsA("BasePart") and not v:IsDescendantOf(plr.Character) then
			if state then
				if not saved[v] then saved[v]=v.LocalTransparencyModifier end
				v.LocalTransparencyModifier=1
			else
				if saved[v] then v.LocalTransparencyModifier=saved[v] end
			end
		elseif v:IsA("Decal") or v:IsA("Texture") then
			if state then
				if not saved[v] then saved[v]=v.Transparency end
				v.Transparency=1
			else
				if saved[v] then v.Transparency=saved[v] end
			end
		end
	end
	if not state then saved = {} end
end

local function applyBright(mode)
	if brightConn then brightConn:Disconnect() brightConn=nil end
	modeIndex=mode
	updateEffectText()
	updateModeHighlight()
	if mode==1 then
		b2.Text="Mode: BRIGHT"
		brightConn=RS.RenderStepped:Connect(function()
			local intensity=math.clamp(effectLevel,1,10)
			Lighting.ClockTime=14
			Lighting.FogEnd=100000
			Lighting.GlobalShadows=false
			Lighting.Brightness=1+(intensity*0.45)
			local ambient=0.2+(intensity*0.075)
			Lighting.Ambient=Color3.new(ambient,ambient,ambient)
			Lighting.OutdoorAmbient=Color3.new(ambient,ambient,ambient)
			Lighting.ExposureCompensation=intensity*0.22
		end)
	elseif mode==2 then
		b2.Text="Mode: OFF"
		local old=getgenv().BlockVNOriginalLighting
		Lighting.Brightness=old.Brightness
		Lighting.ClockTime=old.ClockTime
		Lighting.FogEnd=old.FogEnd
		Lighting.GlobalShadows=lessVfxEnabled and false or old.GlobalShadows
		Lighting.Ambient=old.Ambient
		Lighting.OutdoorAmbient=old.OutdoorAmbient
		Lighting.ExposureCompensation=old.ExposureCompensation
	elseif mode==3 then
		b2.Text="Mode: DARK"
		brightConn=RS.RenderStepped:Connect(function()
			local darkness=math.clamp(effectLevel,1,10)
			Lighting.ClockTime=0
			Lighting.GlobalShadows=not lessVfxEnabled
			Lighting.FogEnd=3000-(darkness*260)
			Lighting.Brightness=1.5-(darkness*0.13)
			local ambient=math.clamp(0.6-(darkness*0.055),0,1)
			Lighting.Ambient=Color3.new(ambient,ambient,ambient)
			Lighting.OutdoorAmbient=Color3.new(ambient,ambient,ambient)
			Lighting.ExposureCompensation=-(darkness*0.28)
		end)
	end
end

