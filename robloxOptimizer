-- Hop Server logic
local isHopping=false
hopBtn.MouseButton1Click:Connect(function()
	if isHopping then return end
	isHopping=true
	hopBtn.Text="Hopping..."
	hopBtn.BackgroundColor3=Color3.fromRGB(20,60,20)

	local success=false
	pcall(function()
		local servers=HttpService:JSONDecode(game:HttpGet(
			"https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"
		))
		if servers and servers.data then
			local current=game.JobId
			for _,s in ipairs(servers.data) do
				if s.id~=current and s.playing<s.maxPlayers then
					TeleportService:TeleportToPlaceInstance(game.PlaceId,s.id,plr)
					success=true
					break
				end
			end
		end
	end)

	if not success then
		hopBtn.Text="No Server Found!"
		hopBtn.BackgroundColor3=Color3.fromRGB(80,20,20)
		task.wait(2)
		hopBtn.Text="Hop Server"
		hopBtn.BackgroundColor3=Color3.fromRGB(30,30,30)
		isHopping=false
	end
end)

